# Copy this file to .env and edit with your values, then run: docker compose up -d
# Required: set a strong TUDUDI_USER_PASSWORD and TUDUDI_SESSION_SECRET in .env

# Admin login email
TUDUDI_USER_EMAIL=email@example.com

# Admin password - MUST change in production
TUDUDI_USER_PASSWORD=password_must_change

# Session signing secret - MUST change (e.g. generate with: openssl rand -hex 32)
TUDUDI_SESSION_SECRET=secret_must_change

# CORS allowed origins (comma-separated)
TUDUDI_ALLOWED_ORIGINS=https://tududi.example.com

BACKEND_URL=https://tududi.example.com

# Enable Swagger API documentation
SWAGGER_ENABLED=false

# Trust X-Forwarded-* headers (set true behind reverse proxy)
TUDUDI_TRUST_PROXY=false

# Path for uploads inside the container
TUDUDI_UPLOAD_PATH=/app/backend/uploads

# Telegram
FF_ENABLE__TELEGRAM=false

# Scheduler
FF_ENABLE_SCHEDULER=true

# Calendar
FF_ENABLE_CALENDAR=false

# Habits
FF_ENABLE_HABITS=true

# Run-as UID/GID - set to match your host user for volume permissions
PUID=1000
PGID=1000
